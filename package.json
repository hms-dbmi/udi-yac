{
  "name": "udi-yac",
  "version": "0.1.2",
  "description": "React implementation of the Universal Discovery Interface (UDI) chat — natural-language querying and visualization of biomedical datasets. Publishable as a library (`UDIChat` component) or as a standalone SPA.",
  "keywords": [
    "udi",
    "udi-yac",
    "udi-chat",
    "react",
    "visualization",
    "vega-lite",
    "biomedical",
    "hubmap",
    "llm",
    "chat"
  ],
  "homepage": "https://github.com/NickAkhmetov/udi-chat-react#readme",
  "bugs": {
    "url": "https://github.com/NickAkhmetov/udi-chat-react/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NickAkhmetov/udi-chat-react.git"
  },
  "license": "MIT",
  "type": "module",
  "main": "dist/udi-yac.js",
  "module": "dist/udi-yac.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/udi-yac.js"
    },
    "./style.css": "./dist/udi-yac.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "tsc -b && vite build --mode lib",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "prepare": "husky"
  },
  "packageManager": "pnpm@10.27.0",
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md,html,yaml,yml}": "prettier --write"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "arquero": "^8.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jszip": "^3.10.1",
    "lucide-react": "^1.7.0",
    "lz-string": "^1.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "shadcn": "^4.1.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "udi-toolkit": "^0.0.55",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/lz-string": "^1.5.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-project-structure": "^3.14.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.4.2",
    "rolldown": "1.0.0-rc.12",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vega": "^6.2.0",
    "vega-embed": "^7.1.0",
    "vite": "^8.0.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^2.1.8"
  }
}
