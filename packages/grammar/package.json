{
  "name": "udi-toolkit",
  "version": "0.0.69",
  "description": "Universal Discovery Interface Toolkit",
  "author": "dev-lan <devinscottlange@gmail.com>",
  "type": "module",
  "private": false,
  "main": "dist/index.cjs",
  "homepage": "https://hms-dbmi.github.io/udi-yac/grammar/",
  "module": "dist/index.js",
  "umd": "dist/index.umd.cjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./ce": {
      "types": "./ce.d.ts",
      "import": "./dist/ce.js"
    },
    "./react": {
      "types": "./dist/react-wrapper/index.d.ts",
      "import": "./dist/react.js"
    },
    "./style.css": "./dist/index.css",
    "./dist/index.css": "./dist/index.css",
    "./dist/DataSourcesStore.d.ts": "./dist/DataSourcesStore.d.ts",
    "./dist/GrammarTypes": {
      "types": "./dist/GrammarTypes.d.ts",
      "default": "./dist/GrammarTypes.d.ts"
    },
    "./dist/GrammarTypes.d.ts": "./dist/GrammarTypes.d.ts"
  },
  "files": [
    "dist",
    "ce.d.ts"
  ],
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "test": "npm run build:all && node test/smoke-vue.mjs && node test/smoke-ce.mjs && node test/smoke-react.mjs && node test/smoke-exports.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "build-schema": "ts-json-schema-generator --path './GrammarTypes.ts' --type 'UDIGrammar' --tsconfig ./tsconfig.json > UDIGrammarSchema.json",
    "build": "vite build",
    "build:ce": "vite build --config vite.config.ce.ts",
    "build:react": "vite build --config vite.config.react.ts",
    "build:all": "npm run build && npm run build:ce && npm run build:react",
    "prepublishOnly": "npm run build:all",
    "npm-publish": "npm publish --access public"
  },
  "dependencies": {
    "@types/d3-scale": "^4.0.9",
    "@types/d3-scale-chromatic": "^3.1.0",
    "ag-grid-community": "33.2.4",
    "ag-grid-vue3": "33.2.4",
    "arquero": "^8.0.1",
    "d3-scale": "^4.0.2",
    "d3-scale-chromatic": "^3.1.0",
    "fast-kde": "^0.2.2",
    "lodash": "^4.17.23",
    "vega": "^6.2.0",
    "vega-embed": "^7.1.0",
    "vega-lite": "^6.4.2"
  },
  "peerDependencies": {
    "ag-grid-community": "33.2.4",
    "pinia": "^3.0.1",
    "react": "^18.0.0 || ^19.0.0",
    "vue": "^3.4.18"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    },
    "pinia": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^3.2.4",
    "@eslint/js": "^9.14.0",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/addon-interactions": "^8.6.18",
    "@storybook/addon-onboarding": "^8.6.18",
    "@storybook/blocks": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "@storybook/vue3": "^8.6.18",
    "@storybook/vue3-vite": "^8.6.18",
    "@types/lodash": "^4.17.16",
    "@types/node": "^20.5.9",
    "@types/react": "^19.2.14",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/eslint-config-typescript": "^14.1.3",
    "autoprefixer": "^10.4.2",
    "eslint": "^9.23.0",
    "eslint-plugin-vue": "^10.0.0",
    "globals": "^15.12.0",
    "prettier": "^3.3.3",
    "storybook": "^8.6.18",
    "ts-json-schema-generator": "^2.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.1",
    "vite-plugin-dts": "^5.0.2",
    "vue-tsc": "^3.3.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hms-dbmi/udi-yac",
    "directory": "packages/grammar"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "^28 || ^26 || ^24 || ^22",
    "npm": ">= 6.13.4"
  }
}
