# Your OpenAI API key. Leave blank to require callers to bring their own key
# via the X-OpenAI-Key header (e.g. the chat app's in-app key prompt).
OPENAI_API_KEY=

# Local dev: skip JWT auth. Unset (or 0) in production and set JWT_SECRET_KEY.
INSECURE_DEV_MODE=1
# JWT_SECRET_KEY=your-key-goes-here

# GPT model for orchestration (optional, defaults to gpt-5.4)
# GPT_MODEL_NAME=gpt-5.4

# LangFuse observability (optional)
# LANGFUSE_SECRET_KEY=sk-your-key-goes-here
# LANGFUSE_PUBLIC_KEY=pk-your-key-goes-here
# LANGFUSE_BASE_URL=https://your-langfuse-instance.com

# Server-side query backends (optional): path to a JSON config mapping
# package names to StarRocks/DuckDB connections, served via /v1/yac/query
# and /v1/yac/metadata. Generated by scripts/seed_starrocks.py — see
# dev/starrocks/README.md.
# UDI_QUERY_BACKENDS=starrocks-backends.json
