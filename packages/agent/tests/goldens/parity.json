    {
      "name": "orderby-rank-ternary",
      "spec": {
        "source": {
          "name": "penguins",
          "source": "penguins.csv"
        },
        "transformation": [
          {
            "groupby": "island"
          },
          {
            "rollup": {
              "n": {
                "op": "count"
              }
            }
          },
          {
            "orderby": {
              "field": "n",
              "order": "desc"
            }
          },
          {
            "derive": {
              "rank": {
                "window": "rank"
              }
            }
          },
          {
            "derive": {
              "top": {
                "if": {
                  "op": "==",
                  "left": {
                    "field": "rank"
                  },
                  "right": {
                    "literal": 1
                  }
                },
                "then": {
                  "literal": "yes"
                },
                "else": {
                  "literal": "no"
                }
              }
            }
          }
        ]
      },
      "selections": null,
      "displayDataOnly": null,
