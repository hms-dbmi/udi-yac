    {
      "name": "derive-ratio-and-ternary",
      "spec": {
        "source": {
          "name": "penguins",
          "source": "penguins.csv"
        },
        "transformation": [
          {
            "filter": {
              "op": "!=",
              "left": {
                "field": "body_mass_g"
              },
              "right": {
                "literal": null
              }
            }
          },
          {
            "filter": {
              "op": "!=",
              "left": {
                "field": "flipper_length_mm"
              },
              "right": {
                "literal": null
              }
            }
          },
          {
            "groupby": "species"
          },
          {
            "rollup": {
              "mass": {
                "op": "sum",
                "field": "body_mass_g"
              },
              "flipper": {
                "op": "sum",
                "field": "flipper_length_mm"
              }
            }
          },
          {
            "derive": {
              "ratio": {
                "op": "/",
                "left": {
                  "field": "mass"
                },
                "right": {
                  "field": "flipper"
                }
              },
              "size": {
                "if": {
                  "op": ">",
                  "left": {
                    "field": "mass"
                  },
                  "right": {
                    "literal": 1000000
                  }
                },
                "then": {
                  "literal": "big"
                },
                "else": {
                  "literal": "small"
                }
              }
            }
          }
        ]
      },
      "selections": null,
      "displayDataOnly": null,
      "expect": {
        "displayData": [
          {
            "species": "Adelie",
            "mass": 558800,
            "flipper": 28683,
