# Standalone-app config (read in src/App.tsx). Copy to .env.local to override.
# All variables are optional — App.tsx ships sensible defaults for local dev.

# UDIAgent FastAPI server URL.
VITE_UDI_API_BASE_URL=http://localhost:8007

# Optional override for the data source. When unset, the standalone app
# defaults to the bundled /data/hubmap/datapackage.json — a reproducible
# HuBMAP snapshot synced from the repo-root sample-data/ into public/data on
# dev/build. Set this to the live portal
# (https://portal.hubmapconsortium.org/metadata/v0/udi/datapackage.json) or
# any other URL the backend can reach. The agent needs no toggle — chat sends
# the loaded package's schema + domains with each request.
# VITE_UDI_DATA_PACKAGE=https://portal.hubmapconsortium.org/metadata/v0/udi/datapackage.json
# Bundled pediatric CNS-tumor (pcx) package, generated by scripts/gen_datapackage.py:
# VITE_UDI_DATA_PACKAGE=/data/pcx/datapackage.json

# Whether to prompt for an OpenAI key in the UI. Default here is "false" for
# local dev: the agent uses the OPENAI_API_KEY from packages/agent/.env, so no
# UI prompt is needed. Set "true" to test the bring-your-own-key flow (the UI
# key is then sent via X-OpenAI-Key and overrides the server's key).
VITE_UDI_REQUIRE_API_KEY=false

# Optional LLM model name override forwarded to the backend.
# VITE_UDI_MODEL=agenticx/UDI-VIS-Beta-v2

# Server-side data package (non-interactive mode). Set to the name of a query
# backend configured on the agent server (UDI_QUERY_BACKENDS). When set, no
# CSVs load in the browser: metadata comes from /v1/yac/metadata and all data
# queries go through /v1/yac/query. Takes precedence over
# VITE_UDI_DATA_PACKAGE.
# VITE_UDI_REMOTE_PACKAGE=my_starrocks_package
